# Copy to .env and update values for local development
# Use this when running with Docker Compose or locally.

# Backend server port
PORT=5000

# MongoDB connection (used when switching to persistent DB)
MONGODB_URI=mongodb://localhost:27017/whereismybus

# Redis connection for scaling WebSockets
REDIS_URL=redis://localhost:6379

# JWT secret for auth (replace in production)
JWT_SECRET=your_jwt_secret_here

# Optional: Paths to SSL certificate and key files for HTTPS (local dev)
# Example (Windows): C:\certs\localhost-key.pem
# Example (Unix): /home/user/certs/localhost-key.pem
SSL_KEY_PATH=
SSL_CERT_PATH=
SENTRY_DSN=
LOG_LEVEL=info
